# Copy this file to config/config.xmonitor.env inside your MagicMirror checkout.
# Do not commit config/config.xmonitor.env.

# Required private X Monitor API settings. Values should be supplied privately.
# Do not include a trailing slash in the base URL.
XMONITOR_MM_API_BASE_URL=
XMONITOR_MM_FEED_PATH=
XMONITOR_MM_TRENDS_PATH=
XMONITOR_MM_SUMMARIES_PATH=

# MagicMirror server options for the X Monitor dashboard.
XMONITOR_MM_ADDRESS=127.0.0.1
XMONITOR_MM_PORT=8091
XMONITOR_MM_TITLE=X Monitor
XMONITOR_MM_REFRESH_INTERVAL_MS=120000
XMONITOR_MM_REQUEST_TIMEOUT_MS=12000
XMONITOR_MM_LOCAL_CONTROLS=true

# Optional API key/header secret for a private API.
# The module helper reads this env var server-side; it is not sent as browser
# module config.
SECRET_XMONITOR_MM_API_KEY=

# Default dashboard filters. Comma-separate multi-value settings.
# Significant can be true, false, or any.
XMONITOR_MM_SIGNIFICANT=true
XMONITOR_MM_TREND_RANGE=24h
XMONITOR_MM_FEED_LIMIT=12
XMONITOR_MM_MAX_FEED_ITEMS=7
XMONITOR_MM_FEED_ONLY_MAX_FEED_ITEMS=18
XMONITOR_MM_TIERS=
XMONITOR_MM_THEMES=
XMONITOR_MM_DEBATE_ISSUES=
XMONITOR_MM_HANDLES=
XMONITOR_MM_LOCATION=
XMONITOR_MM_QUERY=
XMONITOR_MM_SINCE=
XMONITOR_MM_UNTIL=
XMONITOR_MM_MIN_FOLLOWERS=
XMONITOR_MM_MAX_FOLLOWERS=
XMONITOR_MM_MIN_ACCOUNT_AGE_DAYS=
XMONITOR_MM_MAX_ACCOUNT_AGE_DAYS=
